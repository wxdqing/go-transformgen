package {{ .Package }}

import (
	context "{{ .RuntimeImports.Context }}"
	"fmt"

	bootstrap "{{ .RuntimeImports.Bootstrap }}"
	{{ if eq .Refs.FrameCodec "frame.FrameCodec" -}}
	frame "{{ .RuntimeImports.Frame }}"
	{{ end -}}
	{{ if eq .Refs.Registry "registry.Registry" -}}
	registry "{{ .RuntimeImports.Registry }}"
	{{ end -}}
	fx "{{ .RuntimeImports.FX }}"
	proto "{{ .RuntimeImports.Proto }}"
)

type HandlerModule interface {
	ModuleName() string
	Module() any
}

type HandlerModuleOut struct {
	fx.Out

	Module HandlerModule `group:"transformgen_handler_modules"`
}

type HandlerModuleWithBean[T HandlerModule] struct {
	fx.Out

	Module HandlerModule `group:"transformgen_handler_modules"`
	Self   T
}

func NewHandlerModule(module HandlerModule) HandlerModuleOut {
	return HandlerModuleOut{Module: module}
}

func NewHandlerModuleWithBean[T HandlerModule](module T) HandlerModuleWithBean[T] {
	return HandlerModuleWithBean[T]{Module: module, Self: module}
}

type moduleParams struct {
	fx.In

	Modules []HandlerModule `group:"transformgen_handler_modules"`
}

type Provider struct {
	bootstrap.NopHook
	Codec {{ .Refs.FrameCodec }}
}

var _ bootstrap.Provider = Provider{}

func (p Provider) Register() any {
	return func(pms moduleParams) *Module {
		return NewModule(p.Codec, pms)
	}
}

func (Provider) OnStart() any {
	return func(ctx context.Context, m *Module) error {
		return m.Start(ctx)
	}
}

type Module struct {
	Registry {{ .Refs.Registry }}
	Codec    {{ .Refs.FrameCodec }}
	modules  []HandlerModule
}

type Protocol = Module

func NewModule(codec {{ .Refs.FrameCodec }}, p moduleParams) *Module {
	if codec == nil {
		codec = {{ .Refs.PacketFrameCodec }}{}
	}
	return &Module{Codec: codec, modules: p.Modules}
}

func NewProtocol(codec {{ .Refs.FrameCodec }}) (*Protocol, error) {
	m := NewModule(codec, moduleParams{})
	if err := m.Start(context.Background()); err != nil {
		return nil, err
	}
	return m, nil
}

func (m *Module) Start(_ context.Context) error {
	if m == nil {
		return fmt.Errorf("%w: nil protocol module", {{ .Refs.ErrHandlerNotFound }})
	}
	reg := {{ .Refs.RegistryNew }}()
	if err := RegisterMessages(reg); err != nil {
		return err
	}
	m.Registry = reg
	for _, module := range m.modules {
		if module == nil {
			return fmt.Errorf("%w: nil handler module", {{ .Refs.ErrInvalidMessageType }})
		}
		if err := m.RegisterHandlers(module.ModuleName(), module.Module()); err != nil {
			return err
		}
	}
	return nil
}

func (m *Module) RegisterHandlers(modelName string, impl any) error {
	if m == nil || m.Registry == nil {
		return fmt.Errorf("%w: nil protocol registry", {{ .Refs.ErrHandlerNotFound }})
	}
	return RegisterHandlers(m.Registry, modelName, impl)
}

func (m *Module) PackMessage(head {{ .Refs.Head }}, msg proto.Message) ([]byte, func(), error) {
	if m == nil {
		return nil, func() {}, fmt.Errorf("%w: nil protocol", {{ .Refs.ErrInvalidMessageType }})
	}
	return PackMessage(m.Codec, head, msg)
}

func PackMessage(codec {{ .Refs.FrameCodec }}, head {{ .Refs.Head }}, msg proto.Message) ([]byte, func(), error) {
	if codec == nil {
		codec = {{ .Refs.PacketFrameCodec }}{}
	}
	body, err := proto.Marshal(msg)
	if err != nil {
		return nil, func() {}, err
	}
	return codec.EncodeFrame(head, body)
}

func RegisterHandlers(reg {{ .Refs.HandlerRegistry }}, modelName string, impl any) error {
	switch modelName {
	{{ range .Modules -}}
	case {{ .ConstName }}:
		if handler, ok := impl.({{ .InterfaceName }}); ok {
			return register{{ .InterfaceName }}Handlers(reg, handler)
		}
		return fmt.Errorf("%w: %s", {{ $.Refs.ErrInvalidMessageType }}, modelName)
	{{ end -}}
	default:
		return fmt.Errorf("%w: model %s", {{ .Refs.ErrHandlerNotFound }}, modelName)
	}
}
