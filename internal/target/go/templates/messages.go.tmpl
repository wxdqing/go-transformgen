package {{ .Package }}

import (
	{{ range .Imports -}}
	{{ .Name }} "{{ .Path }}"
	{{ end -}}
	{{ if eq .Refs.MessageRegistry "registry.MessageRegistry" -}}
	registry "{{ .RuntimeImports.Registry }}"
	{{ end -}}
	proto "{{ .RuntimeImports.Proto }}"
)

{{ range .Messages -}}
const {{ .ConstName }} uint32 = {{ .ID }}
{{ end }}

func RegisterMessages(reg {{ .Refs.MessageRegistry }}) error {
	{{ range .Messages -}}
	if err := reg.Register{{ .KindSuffix }}({{ $.Refs.MessageMeta }}{ID: {{ .ConstName }}, Kind: {{ if eq .KindSuffix "Request" }}{{ $.Refs.MessageKindRequest }}{{ else if eq .KindSuffix "Response" }}{{ $.Refs.MessageKindResponse }}{{ else }}{{ $.Refs.MessageKindNotify }}{{ end }}, FullName: "{{ .FullName }}"}, func() proto.Message { return &{{ .GoType }}{} }); err != nil {
		return err
	}
	{{ end -}}
	return nil
}
