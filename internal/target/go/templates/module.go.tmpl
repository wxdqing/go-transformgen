package {{ .Package }}

import (
	{{ range .Imports -}}
	{{ if .Name }}{{ .Name }} {{ end }}"{{ .Path }}"
	{{ end -}}
	{{ if and .HasRequester (eq .Refs.FrameCodec "frame.FrameCodec") -}}
	frame "{{ .RuntimeImports.Frame }}"
	{{ end -}}
	{{ if and (or .HasRequester .HasResponder) (eq .Refs.HandlerRegistry "registry.HandlerRegistry") -}}
	registry "{{ .RuntimeImports.Registry }}"
	{{ end -}}
	proto "{{ .RuntimeImports.Proto }}"
)

const {{ .ConstName }} = "{{ .Name }}"

{{ if .HasResponder -}}
type {{ .InterfaceName }} interface {
	{{ range .RPCs -}}
	{{ .Method }}(ctx {{ .Ctx }}, req *{{ .RequestType }}) (*{{ .ResponseType }}, error)
	{{ end -}}
	{{ range .Notifies -}}
	{{ .Method }}(ctx {{ .Ctx }}, msg *{{ .MessageType }}) error
	{{ end -}}
}

func register{{ .InterfaceName }}Handlers(reg {{ .Refs.HandlerRegistry }}, impl {{ .InterfaceName }}) error {
	{{ range .RPCs -}}
	if err := reg.RegisterRequestHandler({{ .ModelConst }}, {{ .RequestConst }}, {{ .ResponseConst }}, func(ctx any, req proto.Message) (proto.Message, error) {
		typedCtx, ok := ctx.({{ .Ctx }})
		if !ok {
			return nil, {{ $.Refs.ErrInvalidContextType }}
		}
		typedReq, ok := req.(*{{ .RequestType }})
		if !ok {
			return nil, {{ $.Refs.ErrInvalidMessageType }}
		}
		return impl.{{ .Method }}(typedCtx, typedReq)
	}); err != nil {
		return err
	}
	{{ end -}}
	{{ range .Notifies -}}
	if err := reg.RegisterNotifyHandler({{ .ModelConst }}, {{ .MessageConst }}, func(ctx any, msg proto.Message) error {
		typedCtx, ok := ctx.({{ .Ctx }})
		if !ok {
			return {{ $.Refs.ErrInvalidContextType }}
		}
		typedMsg, ok := msg.(*{{ .MessageType }})
		if !ok {
			return {{ $.Refs.ErrInvalidMessageType }}
		}
		return impl.{{ .Method }}(typedCtx, typedMsg)
	}); err != nil {
		return err
	}
	{{ end -}}
	return nil
}
{{ end -}}

{{ if .HasRequester -}}
{{ range .RPCs -}}
func Encode{{ .Method }}Request(codec {{ $.Refs.FrameCodec }}, requestID uint64, req *{{ .RequestType }}) ([]byte, func(), error) {
	if codec == nil {
		codec = {{ $.Refs.PacketFrameCodec }}{}
	}
	body, err := proto.Marshal(req)
	if err != nil {
		return nil, func() {}, err
	}
	return codec.EncodeFrame({{ $.Refs.Head }}{MessageID: {{ .RequestConst }}, RequestID: requestID}, body)
}

func Decode{{ .Method }}Response(messageID uint32, payload []byte) (*{{ .ResponseType }}, error) {
	if messageID != {{ .ResponseConst }} {
		return nil, {{ $.Refs.ErrMessageKindMismatch }}
	}
	var resp {{ .ResponseType }}
	if err := proto.Unmarshal(payload, &resp); err != nil {
		return nil, err
	}
	return &resp, nil
}
{{ end -}}

{{ range .Notifies -}}
func Encode{{ .Method }}Notify(codec {{ $.Refs.FrameCodec }}, msg *{{ .MessageType }}) ([]byte, func(), error) {
	if codec == nil {
		codec = {{ $.Refs.PacketFrameCodec }}{}
	}
	body, err := proto.Marshal(msg)
	if err != nil {
		return nil, func() {}, err
	}
	return codec.EncodeFrame({{ $.Refs.Head }}{MessageID: {{ .MessageConst }}}, body)
}
{{ end -}}
{{ end -}}
